# ============================================================
# Brewery Distribution App - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# Google Sheets Spreadsheet ID
# Found in the URL: https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# Google Service Account Authentication
# Option 1: Path to your service account JSON key file (relative to project root)
GOOGLE_KEY_FILE=credentials.json

# Option 2: Inline JSON credentials (useful for cloud/production deployments)
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"your-sa@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Server port (optional, defaults to 3000)
PORT=3000

# ── Webhooks ──────────────────────────────────────────────────────
# Secret token that authorises incoming Zapier webhook calls.
# Set this to a long random string (e.g. openssl rand -hex 32).
# If left unset, the /webhooks/zapier/sale endpoint returns 503.
#
# In Zapier:  Action → Webhooks by Zapier → POST
#             Add header:  Authorization: Bearer <this value>
WEBHOOK_SECRET=your_webhook_secret_here

# ── Google OAuth (Login / Authentication) ─────────────────────────
# Create OAuth 2.0 credentials in Google Cloud Console:
#   1. Go to https://console.cloud.google.com → APIs & Services → Credentials
#   2. Create an OAuth 2.0 Client ID (Web application type)
#   3. Add your domain to "Authorised JavaScript origins"
#   4. Add <your-domain>/auth/google/callback to "Authorised redirect URIs"
#      (for local dev: http://localhost:3000/auth/google/callback)
#
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here

# The OAuth callback URL registered in Google Cloud Console.
# Defaults to /auth/google/callback (works for local dev without setting this).
# For production set the full URL, e.g. https://app.yourdomain.com/auth/google/callback
# GOOGLE_CALLBACK_URL=https://app.yourdomain.com/auth/google/callback

# Restrict sign-in to a single Google Workspace domain (recommended).
# Only users whose Google account belongs to this domain will be allowed in.
# Leave blank to allow any Google account (not recommended for internal tools).
GOOGLE_ALLOWED_DOMAIN=yourcompany.com

# Secret used to sign the session cookie.
# Set this to a long random string (e.g. openssl rand -hex 32).
SESSION_SECRET=your_session_secret_here
